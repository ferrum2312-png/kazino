# Frontend env. Copy to .env for local overrides.
# When empty, the app talks to /api and proxies through Vite to the backend.
VITE_API_BASE=/api
# Optional: absolute WS base, e.g. ws://localhost:8000/api. Leave empty to use the Vite proxy.
VITE_WS_BASE=
# Dev-server proxy target (used by vite.config.js).
VITE_PROXY_TARGET=http://localhost:8000
