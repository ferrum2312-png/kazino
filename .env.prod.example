# Copy to ".env" on the server, then fill in real values.
#   cp .env.prod.example .env
# Generate secrets with:  openssl rand -hex 32

# Signs JWTs — must be long, random, and secret.
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# Telegram bot token from @BotFather (required for Mini App login).
BOT_TOKEN=123456789:AA...your-bot-token...

# Optional TonAPI key (free at tonconsole.com) for reliable deposit polling.
# Works without it at lower rate limits.
TON_API_KEY=
# Price per Telegram Star in USD (50 Stars = $0.75 -> 0.015). Tune to taste.
STAR_USD_PRICE=0.015

# Crypto Pay (@CryptoBot) API token — from @CryptoBot -> Crypto Pay -> My Apps.
# NEVER commit this; it lives only here on the server.
CRYPTO_PAY_TOKEN=
# Use https://testnet-pay.crypt.bot for a testnet app token.
CRYPTO_PAY_BASE=https://pay.crypt.bot

# Internal Postgres password (not exposed publicly, but keep it strong).
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Public domain. Must have a DNS A record pointing at THIS server's public IP.
SITE_ADDRESS=titorovka.icu

# Email for Let's Encrypt notices (expiry warnings). Any real inbox you own.
ACME_EMAIL=you@example.com
